# Supabase Project URL
# Found in: Supabase Dashboard → Project Settings → API → Project URL
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Publishable (anon) Key
# Found in: Supabase Dashboard → Project Settings → API → anon / public
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Direct Database Connection String (PostgreSQL)
# Found in: Supabase Dashboard → Project Settings → Database → Connection string → URI
# Use this for migrations/scripts only — NOT in the app
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.your-project-id.supabase.co:5432/postgres
